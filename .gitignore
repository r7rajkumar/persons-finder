/.nb-gradle/

# VS Code / Kiro
.vscode/
.kiro/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Environment / secrets — none committed today (mock AI service), but keeps any
# future real-LLM API key out of source control by default.
.env
.env.local
*.env.local

# H2 file-mode database artifacts — the app uses in-memory H2 by default
# (jdbc:h2:mem:testdb), so these won't normally appear, but this guards
# against accidentally committing a local file-mode DB.
*.mv.db
*.trace.db

# Docker — local override files reviewers may add without touching the
# tracked docker-compose.yml
docker-compose.override.yml

# Spring Boot
HELP.md